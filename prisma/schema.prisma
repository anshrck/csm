// CereBree uSMS — Universal Service Management System
// Prisma schema (SQLite)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   // SERVICE_CUSTOMER | SCM_WORKER | CM_LEADER | SERVICE_OWNER
  orgNodeId    String?
  avatarColor  String   @default("#0d9488")
  title        String?  // job title for display
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orgNode            OrgNode?          @relation(fields: [orgNodeId], references: [id])
  assignedDemands    Demand[]          @relation("ScmWorkerDemands")
  submittedDemands   Demand[]          @relation("DemandSubmitter")
  ceWorkerChanges    Change[]          @relation("CeWorkerChanges")
  events             DemandEvent[]     @relation("DemandEventActor")
  notifications      Notification[]
  // Phase 2-6 relations
  assignedTickets    Ticket[]          @relation("TicketAssignee")
  requestedTickets   Ticket[]          @relation("TicketRequester")
  ticketEvents       TicketEvent[]
  comments           Comment[]
  attachments        Attachment[]
  auditLogs          AuditLog[]
  knowledgeArticles  KnowledgeArticle[] @relation("KnowledgeAuthor")
  reviewedArticles   KnowledgeArticle[] @relation("KnowledgeReviewer")
  surveys            SatisfactionSurvey[]
  customerAssignments CustomerAssignment[]
  knowledgeVersions   KnowledgeArticleVersion[] @relation("KnowledgeVersionCreator")

  @@index([role])
}

model OrgNode {
  id        String   @id @default(cuid())
  name      String
  type      String   // CUSTOMER_ORG | INTERNAL
  parentId  String?
  createdAt DateTime @default(now())

  parent    OrgNode?  @relation("OrgNodeTree", fields: [parentId], references: [id])
  children  OrgNode[] @relation("OrgNodeTree")
  users     User[]
  demands   Demand[]  @relation("DemandCustomer")
  tickets   Ticket[]  @relation("TicketCustomer")
  slaReportCustomers SlaReportCustomer[]
  customerAssignments CustomerAssignment[]
}

model Service {
  id              String   @id @default(cuid())
  name            String
  description     String
  domain          String   // INTERACTION | SUPPORT | DELIVERY | MANAGEMENT
  chapter         String   // e.g. IDENTITY_ACCESS, COLLABORATION, END_USER_COMPUTE
  layer           String   // BUSINESS | APPLICATION | PLATFORM | INFRASTRUCTURE
  slaClass        String   // A | B | C | D
  status          String   // ACTIVE | RETIRED | PLANNED
  customerValue   String?
  commodityType   String?  // UTILITY | DIFFERENTIATED | STRATEGIC
  supportLevels   String?  // free text
  serviceOwnerId  String
  technicalOwnerId String?
  lastReviewedAt  DateTime?
  nextReviewDue   DateTime?
  lifecycleStage  String?   // PLANNED | ACTIVE | UNDER_REVIEW | RETIREMENT_CANDIDATE | RETIRED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  offerings    ServiceOffering[]
  slaProfiles  SlaProfile[]
  slaEvents    SlaEvent[]
  problems     Problem[]
  // Phase 2-6 relations
  demandServices    DemandService[]
  changeServices    ChangeService[]
  tickets           Ticket[]
  slaPolicies       SlaPolicy[]
  knowledgeArticles KnowledgeArticle[]
  slaReportServices SlaReportService[]
  technicalOwnerTasks TechnicalOwnerTask[]
  // Service Owner Enterprise
  risks         ServiceRisk[]

  @@index([domain])
  @@index([slaClass])
  @@index([status])
}

model ServiceOffering {
  id              String   @id @default(cuid())
  serviceId       String
  name            String
  description     String
  requestType     String   // ACCESS | INCIDENT | SERVICE_REQUEST | DEMAND
  fulfillmentDays Int      @default(5)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  service      Service      @relation(fields: [serviceId], references: [id])
  entitlements Entitlement[]

  @@index([serviceId])
}

model SlaProfile {
  id               String   @id @default(cuid())
  serviceId        String
  slaClass         String   // A | B | C | D
  availabilityTarget Float  // e.g. 99.9
  p1ResponseMins   Int
  p1ResolutionMins Int
  p2ResponseMins   Int
  p2ResolutionMins Int
  createdAt        DateTime @default(now())

  service Service @relation(fields: [serviceId], references: [id])

  @@index([serviceId])
}

model Entitlement {
  id                String    @id @default(cuid())
  orgNodeId         String
  serviceOfferingId String
  scope             String    // DIRECT | INHERITED
  validUntil        DateTime?
  createdAt         DateTime  @default(now())

  offering ServiceOffering @relation(fields: [serviceOfferingId], references: [id])

  @@index([orgNodeId])
}

model Demand {
  id                    String    @id @default(cuid())
  title                 String
  description           String
  businessJustification String?
  desiredTimeline       String?
  relatedServiceIds     String    // JSON array of service ids
  serviceCustomerId     String    // OrgNode id of the customer
  submittedById         String
  assignedScmWorkerId   String?
  status                String    // NEW | UNDER_REVIEW | QUOTED | ACCEPTED | IN_CHANGE | FULFILLED | CLOSED | REJECTED | REDIRECTED
  estimatedEffortDays   Float?
  estimatedCost         Float?
  quoteNotes            String?
  quoteApprovedByCmLeader Boolean @default(false)
  quoteApprovedAt       DateTime?
  commitmentNotes       String?
  rejectionReason       String?
  redirectedToOfferingId String?
  changeRequestId       String?
  quotedAt              DateTime?
  acceptedAt            DateTime?
  handedToCeAt          DateTime?
  fulfilledAt           DateTime?
  closedAt              DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  customer     OrgNode       @relation("DemandCustomer", fields: [serviceCustomerId], references: [id])
  submitter    User          @relation("DemandSubmitter", fields: [submittedById], references: [id])
  scmWorker    User?         @relation("ScmWorkerDemands", fields: [assignedScmWorkerId], references: [id])
  events       DemandEvent[]
  change       Change?       @relation("ChangeOriginDemand")
  handovers    ProcessHandover[] @relation("HandoverDemand")
  // Phase 2-6 relations
  demandServices DemandService[]

  @@index([status])
  @@index([serviceCustomerId])
  @@index([assignedScmWorkerId])
}

model DemandEvent {
  id        String   @id @default(cuid())
  demandId  String
  eventType String   // CREATED | REVIEW_STARTED | QUOTED | QUOTE_APPROVED | ACCEPTED | REJECTED | REDIRECTED | HANDED_TO_CE | FULFILLED | CLOSED | COMMENT
  actorId   String?
  actorName String
  notes     String?
  createdAt DateTime @default(now())

  demand Demand @relation(fields: [demandId], references: [id], onDelete: Cascade)
  actor  User?  @relation("DemandEventActor", fields: [actorId], references: [id])

  @@index([demandId])
}

model SlaEvent {
  id                String    @id @default(cuid())
  serviceId         String
  serviceCustomerId String?
  eventType         String    // WARNING | BREACHED | CLOSED_IN_TIME
  message           String
  createdAt         DateTime  @default(now())
  resolvedAt        DateTime?

  service Service @relation(fields: [serviceId], references: [id])

  @@index([serviceId])
  @@index([eventType])
}

model Change {
  id                       String    @id @default(cuid())
  title                    String
  type                     String    // STANDARD | NORMAL | EMERGENCY
  status                   String    // REQUESTED | ASSESSMENT | PLANNING | APPROVED | IMPLEMENTATION | VERIFICATION | CLOSED | REJECTED
  complexity               String?   // SIMPLE | MEDIUM | COMPLEX
  originType               String    // DEMAND | PROBLEM | STANDARD
  originDemandId           String?   @unique
  originProblemId          String?
  affectedServiceIds       String    // JSON array
  implementationPlan       String?
  technicalOwnerTasksJson  String    // JSON array of tasks
  assignedCeWorkerId       String?
  assignedCeLeaderId       String?
  rejectionReason          String?
  verificationNotes        String?
  catalogUpdatedAt         DateTime?
  isEmergencyPostReviewDue Boolean   @default(false)
  postImplementationReview String?
  approvalNotes            String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  closedAt                 DateTime?

  ceWorker      User?  @relation("CeWorkerChanges", fields: [assignedCeWorkerId], references: [id])
  originDemand  Demand? @relation("ChangeOriginDemand", fields: [originDemandId], references: [id])
  handovers     ProcessHandover[] @relation("HandoverChange")
  // Phase 2-6 relations
  changeServices    ChangeService[]
  technicalOwnerTasks TechnicalOwnerTask[]

  @@index([status])
  @@index([originDemandId])
}

model ProcessHandover {
  id                String    @id @default(cuid())
  type              String    // CM_TO_CE | PM_TO_CE | PM_TO_SD_KE | SD_TO_CE_STD
  sourceDemandId    String?
  sourceProblemId   String?
  targetChangeId    String?
  acknowledgedById  String?
  acknowledgedAt    DateTime?
  createdAt         DateTime  @default(now())

  demand   Demand? @relation("HandoverDemand", fields: [sourceDemandId], references: [id])
  change   Change? @relation("HandoverChange", fields: [targetChangeId], references: [id])

  @@index([type])
}

model Problem {
  id                    String    @id @default(cuid())
  title                 String
  serviceId             String
  status                String    // NEW | UNDER_INVESTIGATION | ROOT_CAUSE_IDENTIFIED | DECISION | KNOWN_ERROR | LINKED_TO_CHANGE | CLOSED
  decision              String?   // KNOWN_ERROR | CHANGE_REQUIRED | FURTHER_ANALYSIS
  rootCauseDescription  String?
  impactAssessment      String?
  decisionRationale     String?
  workaroundDescription String?
  knownErrorId          String?
  assignedPmWorkerId    String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  service Service @relation(fields: [serviceId], references: [id])

  @@index([status])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // DemandQuoted | DemandFulfilled | DemandRejected | SlaWarning | SlaBreached | DemandAccepted | ChangeClosed | DemandCreated | QuoteApprovalRequested | SlaReportApproved | SlaReportReturned | CommitmentApproved | CommitmentEscalated | BreachCommunicated | BreachResponded
  title     String
  message   String
  entityRef String?  // e.g. demand:<id>
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries NotificationDelivery[]

  @@index([userId])
  @@index([read])
}

// SLA performance report prepared by SCM Worker, reviewed/approved by CM Leader
model SlaReport {
  id              String    @id @default(cuid())
  title           String
  periodStart     DateTime
  periodEnd       DateTime
  serviceIds      String    // JSON array (legacy, kept for migration compat)
  serviceCustomerIds String  // JSON array (legacy, kept for migration compat)
  preparedById    String
  reviewedByCmLeaderId String?
  status          String    // DRAFT | PENDING_REVIEW | APPROVED | RETURNED | ISSUED
  summary         String    // compliance summary text
  metricsJson     String    // JSON: per-service compliance, breaches, warnings
  reviewNotes     String?   // CM Leader feedback on return
  approvedAt      DateTime?
  issuedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Phase 2 relations
  reportServices  SlaReportService[]
  reportCustomers SlaReportCustomer[]

  @@index([status])
  @@index([preparedById])
}

// Customer communication record — the governed thread owned by SCM Worker
model Communication {
  id           String    @id @default(cuid())
  demandId     String?
  serviceId    String?
  serviceCustomerId String?
  slaEventId   String?
  direction    String    // TO_CUSTOMER | INTERNAL_NOTE
  channel      String    // PORTAL | EMAIL | MESSAGE
  subject      String
  body         String
  authorId     String
  authorName   String
  createdAt    DateTime  @default(now())

  @@index([demandId])
  @@index([serviceCustomerId])
}

// Service Owner governance decision (commitment approval, escalation, breach response)
model GovernanceDecision {
  id              String    @id @default(cuid())
  serviceId       String
  demandId        String?
  slaEventId      String?
  problemId       String?
  decisionType    String    // COMMITMENT_APPROVAL | COMMITMENT_ESCALATION | BREACH_RESPONSE | LIFECYCLE_DIRECTION | CATALOG_ACCURACY
  decision        String    // APPROVED | REJECTED | ESCALATED | REMEDIATION_AUTHORIZED | RESOURCES_AUTHORIZED | EMERGENCY_CHANGE_DIRECTED
  rationale       String
  resourcesAuthorized String?
  followUpOwner   String?
  followUpDate    DateTime?
  decidedById     String
  decidedByName   String
  createdAt       DateTime  @default(now())

  @@index([serviceId])
  @@index([demandId])
  @@index([decisionType])
}

// ============================================================================
// Phase 2: Join tables (replace JSON string relation fields)
// ============================================================================

model DemandService {
  id        String   @id @default(cuid())
  demandId  String
  serviceId String
  demand    Demand   @relation(fields: [demandId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([demandId, serviceId])
  @@index([serviceId])
}

model ChangeService {
  id        String   @id @default(cuid())
  changeId  String
  serviceId String
  change    Change   @relation(fields: [changeId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([changeId, serviceId])
  @@index([serviceId])
}

model SlaReportService {
  id          String @id @default(cuid())
  slaReportId String
  serviceId   String
  slaReport   SlaReport @relation(fields: [slaReportId], references: [id], onDelete: Cascade)
  service     Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([slaReportId, serviceId])
  @@index([serviceId])
}

model SlaReportCustomer {
  id          String @id @default(cuid())
  slaReportId String
  orgNodeId   String
  slaReport   SlaReport @relation(fields: [slaReportId], references: [id], onDelete: Cascade)
  orgNode     OrgNode   @relation(fields: [orgNodeId], references: [id], onDelete: Cascade)

  @@unique([slaReportId, orgNodeId])
  @@index([orgNodeId])
}

model TechnicalOwnerTask {
  id          String   @id @default(cuid())
  changeId    String
  assigneeId  String?  // User id of the technical owner
  assigneeName String?
  chapter     String?  // ServiceChapter
  ciScope     String?  // CI description
  task        String   // task description
  status      String   @default("PENDING")  // PENDING | IN_PROGRESS | DONE | BLOCKED
  dueAt       DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  change  Change  @relation(fields: [changeId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id])
  serviceId String?

  @@index([changeId])
  @@index([assigneeId])
}

// ============================================================================
// Phase 2: Ticket / Case / Incident domain
// ============================================================================

model Ticket {
  id                String    @id @default(cuid())
  number            String    @unique  // human-readable, e.g. TKT-0001
  title             String
  description       String
  type              String    // INCIDENT | SERVICE_REQUEST | QUESTION | COMPLAINT
  priority          String    // P1 | P2 | P3 | P4
  impact            String?   // LOW | MEDIUM | HIGH
  urgency           String?   // LOW | MEDIUM | HIGH
  status            String    @default("NEW")  // NEW | TRIAGED | ASSIGNED | IN_PROGRESS | WAITING_CUSTOMER | RESOLVED | CLOSED | CANCELED
  serviceId         String?
  serviceCustomerId String    // OrgNode id
  requesterId       String
  assignedUserId    String?
  assignmentGroupId String?
  resolutionCode    String?   // FIXED | WORKAROUND | DUPLICATE | NOT_REPRODUCIBLE | OUT_OF_SCOPE
  resolutionNotes   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  resolvedAt        DateTime?
  closedAt          DateTime?

  service       Service?       @relation(fields: [serviceId], references: [id])
  customer      OrgNode        @relation("TicketCustomer", fields: [serviceCustomerId], references: [id])
  requester     User           @relation("TicketRequester", fields: [requesterId], references: [id])
  assignee      User?          @relation("TicketAssignee", fields: [assignedUserId], references: [id])
  assignmentGroup AssignmentGroup? @relation(fields: [assignmentGroupId], references: [id])
  events        TicketEvent[]
  slaClocks     SlaClock[]

  @@index([status])
  @@index([serviceCustomerId])
  @@index([assignedUserId])
  @@index([priority])
}

model AssignmentGroup {
  id        String   @id @default(cuid())
  name      String
  type      String   // SCM | SERVICE_DESK | TECHNICAL | GOVERNANCE
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  tickets Ticket[]
}

model TicketEvent {
  id        String   @id @default(cuid())
  ticketId  String
  eventType String   // CREATED | ASSIGNED | TRIAGED | IN_PROGRESS | WAITING | RESUMED | RESOLVED | CLOSED | REOPENED | CANCELED | COMMENT
  actorId   String?
  actorName String
  notes     String?
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actor  User?  @relation(fields: [actorId], references: [id])

  @@index([ticketId])
}

// ============================================================================
// Phase 3: SLA Engine
// ============================================================================

model SlaPolicy {
  id                 String   @id @default(cuid())
  name               String
  serviceId          String?
  ticketType         String   // INCIDENT | SERVICE_REQUEST | QUESTION | COMPLAINT | ALL
  priority           String   // P1 | P2 | P3 | P4 | ALL
  responseMins       Int
  resolutionMins     Int
  businessCalendarId String?
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())

  service          Service?         @relation(fields: [serviceId], references: [id])
  businessCalendar BusinessCalendar? @relation(fields: [businessCalendarId], references: [id])
  slaClocks        SlaClock[]
  escalationPolicies SlaEscalationPolicy[]

  @@index([serviceId])
  @@index([priority])
}

model SlaClock {
  id               String    @id @default(cuid())
  ticketId         String
  policyId         String
  type             String    // RESPONSE | RESOLUTION
  status           String    @default("RUNNING")  // RUNNING | PAUSED | MET | BREACHED | CANCELED
  startedAt        DateTime  @default(now())
  dueAt            DateTime
  pausedAt         DateTime?
  totalPausedMins  Int       @default(0)
  metAt            DateTime?
  breachedAt       DateTime?

  ticket Ticket     @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  policy SlaPolicy  @relation(fields: [policyId], references: [id])

  @@index([ticketId])
  @@index([status])
}

model BusinessCalendar {
  id        String   @id @default(cuid())
  name      String
  timezone  String   @default("UTC")
  rulesJson String   // JSON: work hours, holidays, etc.
  createdAt DateTime @default(now())

  policies SlaPolicy[]
}

// ============================================================================
// Phase 4: Threaded comments, attachments, CSAT
// ============================================================================

model Conversation {
  id                String   @id @default(cuid())
  entityType        String   // TICKET | DEMAND | CHANGE | PROBLEM | SLA_EVENT
  entityId          String
  serviceCustomerId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  comments Comment[]

  @@index([entityType, entityId])
}

model Comment {
  id             String   @id @default(cuid())
  conversationId String
  authorId       String
  authorName     String
  visibility     String   @default("CUSTOMER_VISIBLE")  // CUSTOMER_VISIBLE | INTERNAL
  body           String
  createdAt      DateTime @default(now())
  editedAt       DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author       User         @relation(fields: [authorId], references: [id])

  @@index([conversationId])
}

model Attachment {
  id           String   @id @default(cuid())
  entityType   String   // TICKET | DEMAND | CHANGE | PROBLEM | SLA_EVENT | COMMENT
  entityId     String
  fileName     String
  mimeType     String
  sizeBytes    Int
  storageKey   String   // local path or object storage key
  uploadedById String
  createdAt    DateTime @default(now())

  uploader User @relation(fields: [uploadedById], references: [id])

  @@index([entityType, entityId])
}

model SatisfactionSurvey {
  id          String   @id @default(cuid())
  entityType  String   // TICKET | DEMAND
  entityId    String
  customerId  String
  rating      Int      // 1-5
  comment     String?
  createdAt   DateTime @default(now())

  customer User @relation(fields: [customerId], references: [id])

  @@unique([entityType, entityId, customerId])
  @@index([entityType, entityId])
}

// ============================================================================
// Phase 5: Knowledge Base
// ============================================================================

model KnowledgeArticle {
  id          String    @id @default(cuid())
  title       String
  body        String
  type        String    // HOW_TO | KNOWN_ERROR | FAQ | RUNBOOK
  status      String    @default("DRAFT")  // DRAFT | REVIEW | PUBLISHED | RETIRED
  serviceId   String?
  authorId    String
  reviewerId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  service   Service? @relation(fields: [serviceId], references: [id])
  author    User     @relation("KnowledgeAuthor", fields: [authorId], references: [id])
  reviewer  User?    @relation("KnowledgeReviewer", fields: [reviewerId], references: [id])
  versions  KnowledgeArticleVersion[]

  @@index([status])
  @@index([type])
  @@index([serviceId])
}

// ============================================================================
// Phase 6: Permissions and Audit
// ============================================================================

model Permission {
  id          String @id @default(cuid())
  key         String @unique
  description String

  rolePermissions RolePermission[]
}

model RolePermission {
  id           String @id @default(cuid())
  role         String
  permissionId String

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@index([role])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorName  String
  action     String
  entityType String
  entityId   String
  beforeJson String?
  afterJson  String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([action])
  @@index([actorId])
}

// ============================================================================
// Phase 9: Notification delivery
// ============================================================================

model NotificationDelivery {
  id             String   @id @default(cuid())
  notificationId String
  channel        String   // EMAIL | TEAMS | SLACK | PORTAL
  status         String   @default("PENDING")  // PENDING | SENT | FAILED
  error          String?
  sentAt         DateTime?
  createdAt      DateTime @default(now())

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId])
  @@index([status])
}

// ============================================================================
// Enterprise Workflow Review: Customer Assignment (SCM scoping)
// ============================================================================

model CustomerAssignment {
  id        String   @id @default(cuid())
  orgNodeId String
  userId    String
  role      String   // SCM_OWNER | BACKUP | ESCALATION_MANAGER
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  orgNode OrgNode @relation(fields: [orgNodeId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgNodeId, userId, role])
  @@index([userId])
  @@index([orgNodeId])
}

// ============================================================================
// Enterprise Workflow Review: Sequence Counter (race-prone ticket numbers)
// ============================================================================

model SequenceCounter {
  key   String @id
  value Int    @default(0)
}

// ============================================================================
// Enterprise Workflow Review: SLA Escalation Policy
// ============================================================================

model SlaEscalationPolicy {
  id           String  @id @default(cuid())
  policyId     String
  thresholdPct Int     // e.g. 50, 70, 90
  notifyRole   String  // SCM_WORKER | CM_LEADER | SERVICE_OWNER
  notifyUserId String?
  active       Boolean @default(true)
  createdAt    DateTime @default(now())

  policy SlaPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@index([policyId])
}

// ============================================================================
// Enterprise Workflow Review: Knowledge Article Version History
// ============================================================================

model KnowledgeArticleVersion {
  id          String   @id @default(cuid())
  articleId   String
  title       String
  body        String
  version     Int
  createdById String
  createdAt   DateTime @default(now())

  article KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  creator User             @relation("KnowledgeVersionCreator", fields: [createdById], references: [id])

  @@index([articleId])
}

// ============================================================================
// Enterprise Workflow Review: Entity Links (unify demands/tickets/problems)
// ============================================================================

model EntityLink {
  id        String   @id @default(cuid())
  fromType  String   // TICKET | DEMAND | CHANGE | PROBLEM | SLA_EVENT
  fromId    String
  toType    String
  toId      String
  linkType  String   // CAUSED_BY | RELATES_TO | CONVERTED_TO | FULFILLED_BY
  createdBy String?
  createdAt DateTime @default(now())

  @@unique([fromType, fromId, toType, toId, linkType])
  @@index([fromType, fromId])
  @@index([toType, toId])
}

// ============================================================================
// Service Owner Enterprise: Service Risk Register
// ============================================================================

model ServiceRisk {
  id          String    @id @default(cuid())
  serviceId   String
  title       String
  sourceType  String    // SLA | TICKET | PROBLEM | CHANGE | KNOWLEDGE | CSAT | CATALOG
  sourceId    String?
  severity    String    // LOW | MEDIUM | HIGH | CRITICAL
  likelihood  String?   // LOW | MEDIUM | HIGH
  impact      String?   // LOW | MEDIUM | HIGH
  ownerId     String?
  status      String    @default("OPEN")  // OPEN | MITIGATING | ACCEPTED | CLOSED
  mitigation  String?
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@index([status])
  @@index([severity])
}

// ============================================================================
// CM Leader: Managed Portfolio Scope
// ============================================================================

model LeaderManagedScope {
  id        String   @id @default(cuid())
  leaderId  String
  orgNodeId String?
  createdAt DateTime @default(now())

  @@unique([leaderId, orgNodeId])
}
